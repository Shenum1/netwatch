# ── App ──────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── ML Service ───────────────────────────────────────
ML_SERVICE_URL=http://localhost:8000

# ── Database ─────────────────────────────────────────
POSTGRES_URL=postgresql://user:password@localhost:5432/netwatch
REDIS_URL=redis://localhost:6379

# ── Queue (redis | kafka) ────────────────────────────
QUEUE_DRIVER=redis
KAFKA_BROKER=localhost:9092

# ── GeoIP ────────────────────────────────────────────
MAXMIND_LICENSE_KEY=your_key_here

# ── Alerts ───────────────────────────────────────────
SLACK_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_TO=

# ── Auth (optional JWT) ──────────────────────────────
JWT_SECRET=change_me_in_production
